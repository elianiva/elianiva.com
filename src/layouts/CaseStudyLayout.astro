---
import siteData from "~/data/sites";
import type { ProjectMeta } from "~/models/project";
import GithubIcon from "~icons/ph/github-logo-duotone";
import GlobeIcon from "~icons/ph/globe-hemisphere-west-duotone";
import BackButton from "../components/BackButton.astro";
import MainLayout from "./MainLayout.astro";

export type Props = {
	frontmatter: ProjectMeta & {
		context?: string;
		role?: string;
		decisions?: string[];
		outcome?: string;
	};
	slug: string;
};

const { frontmatter, slug } = Astro.props as Props;

const hasCaseStudyFields =
	frontmatter.context ||
	frontmatter.role ||
	(frontmatter.decisions && frontmatter.decisions.length > 0) ||
	frontmatter.outcome;
---

<MainLayout
	seo={{
		title: frontmatter.title,
		description: frontmatter.description,
		thumbnail: `${siteData.siteUrl}/${slug}/cover.webp`,
	}}
>
	<main class="mx-auto max-w-[1080px] px-2 md:px-4 py-10">
		<BackButton />

		<!-- Hero -->
		<section class="pt-6 pb-10 border-b border-pink-200/50">
			<div class="flex flex-col md:flex-row gap-4 items-start md:items-center justify-between pb-6">
				<h1
					class="text-3xl md:text-4xl font-bold font-display text-pink-950 tracking-wide"
				>
					{frontmatter.title}
				</h1>
				<div class="flex gap-2 shrink-0">
					<a
						class="flex gap-2 items-center bg-white/60 hover:bg-white border-[0.5px] border-pink-200/50 hover:border-pink-200 py-2 px-4 text-pink-950 hover:text-pink-800 transition-all focus:outline-none focus:ring focus:ring-pink-400 focus:ring-offset-2"
						href={frontmatter.source}
						target="_blank"
						rel="noopener noreferrer"
					>
						<GithubIcon class="w-5 h-5" />
						<span class="text-sm font-mono uppercase">Source</span>
					</a>
					{
						frontmatter.demo !== null && (
							<a
								class="flex gap-2 items-center bg-pink-50/80 hover:bg-pink-50 border-[0.5px] border-pink-200/50 hover:border-pink-200 py-2 px-4 text-pink-950 hover:text-pink-800 transition-all focus:outline-none focus:ring focus:ring-pink-400 focus:ring-offset-2"
								href={frontmatter.demo}
								target="_blank"
								rel="noopener noreferrer"
							>
								<GlobeIcon class="w-5 h-5" />
								<span class="text-sm font-mono uppercase">Visit</span>
							</a>
						)
					}
				</div>
			</div>

			<p class="text-base md:text-lg font-body text-pink-950/80 max-w-[70ch]">
				{frontmatter.description}
			</p>
		</section>

		<!-- Case Study Fields (optional) -->
		{
			hasCaseStudyFields && (
				<section class="py-8 border-b border-pink-200/50">
					<div class="grid grid-cols-1 md:grid-cols-[2fr_1fr] gap-8">
						<div class="space-y-8">
							{frontmatter.context && (
								<div>
									<h2 class="text-sm font-mono uppercase text-pink-600 tracking-wider pb-2">
										Context
									</h2>
									<p class="text-base font-body text-pink-950/80 leading-relaxed">
										{frontmatter.context}
									</p>
								</div>
							)}

							{frontmatter.role && (
								<div>
									<h2 class="text-sm font-mono uppercase text-pink-600 tracking-wider pb-2">
										My Role
									</h2>
									<p class="text-base font-body text-pink-950/80 leading-relaxed">
										{frontmatter.role}
									</p>
								</div>
							)}

							{frontmatter.decisions && frontmatter.decisions.length > 0 && (
								<div>
									<h2 class="text-sm font-mono uppercase text-pink-600 tracking-wider pb-2">
										Decisions
									</h2>
									<ul class="space-y-3">
										{frontmatter.decisions.map((d: string) => (
											<li class="flex gap-3 text-base font-body text-pink-950/80 leading-relaxed">
												<span class="text-pink-400 shrink-0 mt-1">—</span>
												<span>{d}</span>
											</li>
										))}
									</ul>
								</div>
							)}

							{frontmatter.outcome && (
								<div>
									<h2 class="text-sm font-mono uppercase text-pink-600 tracking-wider pb-2">
										Outcome
									</h2>
									<p class="text-base font-body text-pink-950/80 leading-relaxed">
										{frontmatter.outcome}
									</p>
								</div>
							)}
						</div>

						<aside class="h-fit">
							<h2 class="text-lg font-bold font-display text-pink-950 tracking-wide pb-3 border-b border-pink-200/50">
								Tech Stack
							</h2>
							<div class="space-y-3 pt-4">
								{frontmatter.stack.map(([stackName, stackHomepage]: [string, string]) => (
									<div class="flex items-center gap-3 group">
										<div class="flex items-center justify-center p-2 bg-pink-50/80 border-[0.5px] border-pink-200/50 w-12 h-12 shrink-0">
											<img
												class={`w-full h-full object-contain ${stackName.toLowerCase() === "nextjs" ? "filter invert" : ""}`}
												src={`/assets/logo/${stackName.toLowerCase().replace(/\s+/g, "-")}.png`}
												alt={stackName}
											/>
										</div>
										<a
											href={stackHomepage}
											class="text-sm font-body text-pink-950 hover:text-pink-700 transition-colors focus:outline-none focus:ring focus:ring-pink-400 focus:ring-offset-1"
											target="_blank"
											rel="noopener noreferrer"
										>
											{stackName}
										</a>
									</div>
								))}
							</div>
						</aside>
					</div>
				</section>
			)
		}

		<!-- Screenshot (if hasImage) -->
		{
			frontmatter.hasImage && (
				<section class="py-8">
					<div class="overflow-hidden border-[0.5px] border-pink-200/50">
						<img
							src={`/assets/projects/${slug}/cover.webp`}
							alt={`${frontmatter.title} screenshot`}
							class="block w-full h-full bg-pink-100"
							loading="lazy"
						/>
					</div>
				</section>
			)
		}

		<!-- Main Content (MDX body) -->
		<section class="py-4">
			<div class="grid grid-cols-1 md:grid-cols-[2fr_1fr] gap-8">
				<div class="prose">
					<slot />
				</div>
				<div class="hidden md:block" />
			</div>
		</section>
	</main>
</MainLayout>

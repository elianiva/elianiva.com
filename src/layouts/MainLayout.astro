---
import CanvasBackground from "~/components/CanvasBackground.svelte";
import Footer from "~/components/Footer.astro";
import SEO, { type Props as SEOProps } from "~/components/SEO.astro";
import Frame from "~/components/Frame.svelte";

// fonts
import "@fontsource/chonburi";
import "@fontsource/varela-round";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
import "@fontsource/ibm-plex-mono/400-italic.css";
import { ClientRouter } from "astro:transitions";
import "../index.css";

export interface Props {
	seo: SEOProps;
	isPost?: boolean;
}

const { seo, isPost = false } = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full">
	<head>
		<SEO {...seo} />
		<ClientRouter />
		{!import.meta.env.DEV && (
			<script is:inline defer src="https://cloud.umami.is/script.js" data-website-id="09fb4ce5-10bb-467c-9aee-2c95241715dc"></script>
		)}
	</head>
	<body class="h-full">
		<!-- Skip Navigation Link -->
		<a
			href="#main-content"
			class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-pink-600 text-white px-4 py-2 rounded-md z-50 focus:outline-none focus:ring focus:ring-pink-800"
		>
			Skip to main content
		</a>

		<CanvasBackground client:only />

		<Frame isPost={isPost} client:load />

		<main id="main-content" role="main">
			<slot />
		</main>

		<Footer />
	</body>
</html>

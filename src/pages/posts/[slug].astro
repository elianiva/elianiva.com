---
import { getCollection, getEntry, render } from "astro:content";
import PostLayout from "~/layouts/PostLayout.astro";

export const prerender = true;

export async function getStaticPaths() {
	const postEntries = await getCollection("posts");
	return postEntries.map((entry) => ({
		params: { slug: entry.id },
	}));
}

const { slug } = Astro.params;
const entry = await getEntry("posts", slug);
if (!entry) {
	return Astro.redirect(`/posts`);
}

const contentWithoutHeaders = entry?.body?.replace(/^(#+\s*)/gm, "");
const wordCount = contentWithoutHeaders?.split(/\s+/).length ?? 0;
const readingTime = Math.ceil(wordCount / 200);

const { Content } = await render(entry);
---

<PostLayout frontmatter={entry.data} slug={entry.id} wordCount={wordCount} readingTime={readingTime}>
	<Content />
</PostLayout>

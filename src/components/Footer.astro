---
const buildDate = new Date().toLocaleString("en-GB", {
	year: "numeric",
	month: "long",
	day: "numeric",
	hour: "numeric",
	minute: "numeric",
	second: "numeric",
});

// Cloudflare Pages injects this at build time; falls back gracefully
const commitHash =
	(import.meta.env.CF_PAGES_COMMIT_SHA as string | undefined)?.slice(0, 7) ??
	"dev";
---

<footer
	class="relative mx-auto max-w-[1080px] px-4 py-10 border-x border-pink-200/50 with-box-upperline"
>
	<div class="flex flex-col items-center gap-3 text-center">
		<p class="text-sm font-light! font-body text-pink-950/50 leading-relaxed">
			made with actual care (and probably too much coffee)<br />
		</p>

		<div class="w-24 h-px bg-pink-200/50"></div>

		<p
			class="text-[11px] font-mono text-pink-950/40 uppercase tracking-[0.15em]"
		>
			astro · svelte · tailwind
		</p>

		<p class="text-xs font-mono text-pink-950/30 lowercase">
			last updated {buildDate} · {commitHash}
		</p>
	</div>
</footer>

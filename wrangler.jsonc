{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "elianiva-com",
	"compatibility_date": "2026-04-20",
	"compatibility_flags": ["nodejs_compat"],
	"workers_dev": true,
	"preview_urls": true,
	"observability": {
		"logs": {
			"enabled": true,
			"invocation_logs": true,
		},
	},
	"assets": {
		"directory": "./dist/client/",
	},
	"vars": {
		"BUN_VERSION": "1.2.15",
		"NODE_VERSION": "22",
		"SKIP_DEPENDENCY_INSTALL": true,
	},
}
